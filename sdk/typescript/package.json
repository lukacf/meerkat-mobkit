{
  "name": "@rkat/mobkit-sdk",
  "version": "0.4.9",
  "description": "MobKit TypeScript SDK — companion orchestration for the Meerkat agent runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-cjs.js",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx --test tests/*.test.ts",
    "validate": "npm run typecheck && npm run build && npm test",
    "parity": "node scripts/parity.cjs",
    "productization": "node scripts/productization.cjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
